<!DOCTYPE html>
<html>
<head>
  <title>QuickGG</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: black;
      color: white;
      overflow-x: hidden;
    }

    .stars {
      position: fixed;
      width: 100%;
      height: 100%;
      background: url('https://www.transparenttextures.com/patterns/stardust.png');
      animation: move 120s linear infinite;
      opacity: 0.4;
      z-index: -1;
    }

    @keyframes move {
      from { transform: translateY(0); }
      to { transform: translateY(-2000px); }
    }

    .navbar {
      padding: 20px;
      background: rgba(255,255,255,0.05);
      border-bottom: 1px solid purple;
    }

    .logo {
      font-size: 40px;
      font-weight: bold;
      color: #b366ff;
    }

    .hero {
      text-align: center;
      padding: 100px 20px;
    }

    .hero h1 {
      font-size: 70px;
    }

    .games {
      display: grid;
      grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
      gap: 20px;
      padding: 40px;
    }

    .card {
      background: rgba(255,255,255,0.05);
      border: 1px solid purple;
      border-radius: 20px;
      padding: 20px;
      transition: 0.3s;
      cursor: pointer;
      text-align: center;
      font-size: 25px;
    }

    .card:hover {
      transform: scale(1.05);
      box-shadow: 0 0 25px purple;
    }
  </style>
</head>

<body>

<div class="stars"></div>

<div class="navbar">
  <div class="logo">QUICKGG</div>
</div>

<div class="hero">
  <h1>Great Popular Games</h1>
  <p>Free to play instantly at school.</p>
</div>

<div class="games">
  <div class="card">Minecraft</div>
  <div class="card">Roblox</div>
  <div class="card">Slope</div>
  <div class="card">Run 3</div>
  <div class="card">1v1.LOL</div>
  <div class="card">Cookie Clicker</div>
</div>

</body>
</html>

