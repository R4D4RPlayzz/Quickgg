<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QuickGG</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial,sans-serif;
background:#050816;
color:white;
overflow-x:hidden;
}

/* SPACE BACKGROUND */

body::before{
content:"";
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:
radial-gradient(circle at top,#6d28d955,transparent 30%),
radial-gradient(circle at bottom,#2563eb55,transparent 30%),
black;
z-index:-2;
}

/* NAVBAR */

.navbar{
padding:25px;
text-align:center;
font-size:50px;
font-weight:900;
letter-spacing:3px;
background:rgba(255,255,255,0.03);
backdrop-filter:blur(10px);
border-bottom:1px solid rgba(255,255,255,0.08);
color:#c084fc;
}

/* HERO */

.hero{
text-align:center;
padding:80px 20px;
}

.hero h1{
font-size:70px;
margin-bottom:15px;
}

.hero p{
font-size:24px;
color:#d1d5db;
}

/* GAME GRID */

.games{
max-width:1400px;
margin:auto;
padding:30px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
gap:30px;
}

.card{
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,255,255,0.08);
border-radius:25px;
overflow:hidden;
transition:0.3s;
cursor:pointer;
backdrop-filter:blur(10px);
}

.card:hover{
transform:translateY(-10px) scale(1.03);
box-shadow:0 0 35px #9333ea;
}

.card:active{
transform:scale(0.96);
}

.card img{
width:100%;
height:180px;
object-fit:cover;
transition:0.3s;
}

.card:hover img{
transform:scale(1.08);
}

.card h2{
padding:18px;
font-size:28px;
text-align:center;
}

/* FOOTER */

.footer{
text-align:center;
padding:40px;
color:#9ca3af;
}

</style>
</head>

<body>

<div class="navbar">
QUICKGG
</div>

<div class="hero">
<h1>PLAY UNBLOCKED GAMES</h1>
<p>The coolest games for school.</p>
</div>

<div class="games">

<div class="card">
<img src="https://upload.wikimedia.org/wikipedia/en/thumb/f/f9/Slope_Run_Game.jpg/320px-Slope_Run_Game.jpg">
<h2>Slope</h2>
</div>

<div class="card">
<img src="https://upload.wikimedia.org/wikipedia/en/0/0f/Run_3_cover.jpg">
<h2>Run 3</h2>
</div>

<div class="card">
<img src="https://play-lh.googleusercontent.com/z2pE7U4gpS3A4QKDMaMGnq6gjK4o9WFm4R8Q9vD0zUNxRj8M5P0K0s0lQh6hLzQ6tA">
<h2>1v1.LOL</h2>
</div>

<div class="card">
<img src="https://upload.wikimedia.org/wikipedia/en/7/7d/Retro_Bowl_cover.jpg">
<h2>Retro Bowl</h2>
</div>

<div class="card">
<img src="https://play-lh.googleusercontent.com/1M2M7GxW9jzQp6k0RvrRZtGJPD7W82dManIeZDV4SSQdlqzTeWY5Avzkdxl3pNGdiszK">
<h2>Basketball Stars</h2>
</div>

<div class="card">
<img src="https://play-lh.googleusercontent.com/2zJjMgeSEB1t9I7H5P4xMIOKgHdwNwp0UrEGouGZWlznImPi0tLxe3LjXLp8dkUBaRd3">
<h2>Drift Hunters</h2>
</div>

</div>

<div class="footer">
© 2026 QUICKGG
</div>

</body>
</html>
